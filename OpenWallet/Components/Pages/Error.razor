@page "/Error"
@using System.Diagnostics

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - OpenWallet</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="d-flex align-items-center justify-content-center" style="min-height:100vh;">
    <div class="text-center">
        <i class="display-1 text-danger">⚠</i>
        <h2 class="mt-3 text-danger">An error occurred</h2>
        @if (ShowRequestId)
        {
            <p class="text-muted">Request ID: <code>@RequestId</code></p>
        }
        <p class="text-muted">Please try reloading the page.</p>
        <a href="/" class="btn btn-primary">Back to Dashboard</a>
    </div>
</body>
</html>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
