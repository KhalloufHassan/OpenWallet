<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["OpenWallet.styles.css"]" />
    <ImportMap />
    <HeadOutlet @rendermode="@(new InteractiveWebAssemblyRenderMode(prerender: false))" />
</head>

<body>
    <div id="app-loading" style="display:flex;align-items:center;justify-content:center;height:100vh;color:#adb5bd;font-family:sans-serif;gap:.75rem;position:fixed;inset:0;background:#0d1117;z-index:10000;">
        <span style="width:1.5rem;height:1.5rem;border:3px solid #0d6efd;border-top-color:transparent;border-radius:50%;display:inline-block;animation:ow-spin 0.7s linear infinite;"></span>
        Loading OpenWallet…
        <style>@@keyframes ow-spin{to{transform:rotate(360deg)}}</style>
    </div>

    <Routes @rendermode="@(new InteractiveWebAssemblyRenderMode(prerender: false))" />

    <div id="blazor-error-ui" data-nosnippet style="display:none;position:fixed;bottom:0;width:100%;background:#da3633;color:#fff;padding:.5rem 1.25rem;z-index:9999;">
        An unhandled error has occurred. <a href="." style="color:#fff;font-weight:600;">Reload</a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="charts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    <script src="auth.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]" autostart="false"></script>
    <script>
        Blazor.start().then(function () {
            var el = document.getElementById('app-loading');
            if (el) el.remove();
        }).catch(function (err) {
            var el = document.getElementById('app-loading');
            if (el) el.innerHTML = '<span style="color:#f85149">&#9888; Failed to load: ' + err + '</span>';
        });
    </script>
</body>

</html>
