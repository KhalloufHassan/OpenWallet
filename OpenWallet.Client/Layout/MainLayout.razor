@inherits LayoutComponentBase
@implements IDisposable
@using OpenWallet.Client.Services
@using OpenWallet.Shared.DTOs
@inject ApiClient Api
@inject NavigationManager Nav
@inject PrivacyService Privacy
@inject LockService Lock

@if (!authChecked)
{
    <div></div>
}
else
{
    <div class="d-flex">
        <div class="sidebar-backdrop @(sidebarOpen ? "show" : "")" @onclick="CloseSidebar"></div>

        <nav class="sidebar d-flex flex-column p-3 @(sidebarOpen ? "sidebar-open" : "")">
            <div class="mb-4 px-2">
                <span class="fw-bold fs-5 text-white">
                    <i class="bi bi-wallet2 me-2 text-primary"></i>OpenWallet
                </span>
            </div>
            <ul class="nav flex-column gap-1 flex-grow-1">
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="accounts">
                        <i class="bi bi-bank me-2"></i>Accounts
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="records">
                        <i class="bi bi-list-ul me-2"></i>Records
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="categories">
                        <i class="bi bi-grid me-2"></i>Categories
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="tags">
                        <i class="bi bi-tags me-2"></i>Tags
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="stores">
                        <i class="bi bi-shop me-2"></i>Stores
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="templates">
                        <i class="bi bi-file-earmark-text me-2"></i>Templates
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="debts">
                        <i class="bi bi-people me-2"></i>Debts
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link px-2 py-2" href="security">
                        <i class="bi bi-shield-lock me-2"></i>Security
                    </NavLink>
                </li>
            </ul>
            <div class="border-top pt-3 mt-2" style="border-color:#30363d!important;">
                @if (!string.IsNullOrEmpty(username))
                {
                    <div class="px-2 mb-2 small text-muted text-truncate">
                        <i class="bi bi-person-circle me-1"></i>@username
                    </div>
                }
                <button class="btn btn-sm btn-outline-secondary w-100" @onclick="DoLogout">
                    <i class="bi bi-box-arrow-right me-1"></i>Sign out
                </button>
            </div>
        </nav>

        <div class="mobile-topbar">
            <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleSidebar" aria-label="Menu">
                <i class="bi bi-list fs-5"></i>
            </button>
            <span class="fw-bold text-white">
                <i class="bi bi-wallet2 me-1 text-primary"></i>OpenWallet
            </span>
        </div>

        <main class="flex-grow-1 p-4 main-content" style="min-height:100vh; overflow-x:hidden;">
            @Body
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet style="display:none;position:fixed;bottom:0;width:100%;background:#da3633;color:white;padding:.5rem 1rem;z-index:9999;">
    An unhandled error has occurred.
    <a href="." class="text-white">Reload</a>
</div>

@code {
    bool authChecked;
    string username = string.Empty;
    bool sidebarOpen;
    DotNetObjectReference<LockService>? lockRef;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;

        SetupStatusDto setup = await Api.GetSetupStatusAsync();
        if (!setup.IsSetupDone)
        {
            Nav.NavigateTo("/setup", forceLoad: false);
            authChecked = true;
            return;
        }

        AuthMeDto? me = await Api.GetMeAsync();
        if (me == null)
        {
            Nav.NavigateTo("/login", forceLoad: false);
            authChecked = true;
            return;
        }

        username = me.Username;
        await Privacy.InitAsync();
        lockRef = DotNetObjectReference.Create(Lock);
        await Lock.InitAsync(lockRef);
        authChecked = true;
    }

    void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        sidebarOpen = false;
        InvokeAsync(StateHasChanged);
    }

    void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    void CloseSidebar()  => sidebarOpen = false;

    async Task DoLogout()
    {
        await Api.LogoutAsync();
        Nav.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        lockRef?.Dispose();
    }
}
