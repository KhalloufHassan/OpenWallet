@using OpenWallet.Shared.DTOs
@using OpenWallet.Shared.Models

<div class="row g-2 align-items-end">
    @if (Accounts.Count > 0)
    {
        <div class="col-6 col-md-3">
            <label class="form-label small text-muted mb-1">Account</label>
            <AccountPicker Accounts="Accounts" Value="Filter.AccountId"
                           ValueChanged="id => Filter.AccountId = id"
                           Nullable="true" NullLabel="All accounts" />
        </div>
    }
    <div class="col-6 col-md-3">
        <label class="form-label small text-muted mb-1">Category</label>
        <CategoryPicker Categories="Categories"
                        Value="Filter.CategoryId"
                        ValueChanged="id => Filter.CategoryId = id"
                        Placeholder="All categories" />
    </div>
    <div class="col-6 col-md-3">
        <label class="form-label small text-muted mb-1">Store</label>
        <StorePicker Stores="Stores" Value="Filter.StoreId"
                     ValueChanged="id => Filter.StoreId = id"
                     Nullable="true" NullLabel="All stores" />
    </div>
    <div class="col-6 col-md-3">
        <label class="form-label small text-muted mb-1">Tags</label>
        <TagsPicker Tags="Tags" SelectedIds="Filter.TagIds"
                    SelectedIdsChanged="ids => Filter.TagIds = ids"
                    Placeholder="All tags" />
    </div>
    <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">Type</label>
        <select class="form-select form-select-sm" value="@Filter.Type"
                @onchange="e => Filter.Type = string.IsNullOrEmpty(e.Value?.ToString()) ? null : Enum.Parse<RecordType>(e.Value.ToString()!)">
            <option value="">All types</option>
            <option value="@RecordType.Expense">Expense</option>
            <option value="@RecordType.Income">Income</option>
            <option value="@RecordType.Transfer">Transfer</option>
        </select>
    </div>
    <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">From</label>
        <input type="date" class="form-control form-control-sm" @bind="Filter.FromDate" />
    </div>
    <div class="col-6 col-md-2">
        <label class="form-label small text-muted mb-1">To</label>
        <input type="date" class="form-control form-control-sm" @bind="Filter.ToDate" />
    </div>
    <div class="col-12 col-md-4">
        <label class="form-label small text-muted mb-1">Search notes</label>
        <input class="form-control form-control-sm" @bind="Filter.Search" placeholder="Search..." />
    </div>
    <div class="col-12 col-md-auto d-flex gap-2">
        <button class="btn btn-primary btn-sm flex-grow-1 flex-md-grow-0" @onclick="() => OnSearch.InvokeAsync()">
            <i class="bi bi-search me-1"></i>Search
        </button>
        <button class="btn btn-outline-secondary btn-sm flex-grow-1 flex-md-grow-0" @onclick="() => OnReset.InvokeAsync()">
            Reset
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public RecordFilterDto Filter { get; set; } = new();
    [Parameter, EditorRequired] public List<CategoryDto> Categories { get; set; } = [];
    [Parameter] public List<AccountDto> Accounts { get; set; } = [];
    [Parameter] public List<StoreDto> Stores { get; set; } = [];
    [Parameter] public List<TagDto> Tags { get; set; } = [];
    [Parameter] public EventCallback OnSearch { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }
}
