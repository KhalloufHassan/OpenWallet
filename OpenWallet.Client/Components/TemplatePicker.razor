@using OpenWallet.Shared.DTOs
@using OpenWallet.Shared.Models

<div class="cat-picker @(FullCover ? "full-cover" : "")">
    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="Open">
        Templates
    </button>

    @if (open)
    {
        @if (!FullCover)
        {
            <div class="cat-picker-backdrop" @onclick="Close"></div>
        }
        <div class="cat-picker-panel @(FullCover ? "full-cover" : "")">
            <div class="cat-picker-search">
                <i class="bi bi-search text-muted me-2"></i>
                <input class="cat-picker-input" @bind="search" @bind:event="oninput"
                       placeholder="Search templates…" />
                @if (!string.IsNullOrEmpty(search))
                {
                    <button class="cat-picker-clear" @onclick="() => search = string.Empty">
                        <i class="bi bi-x"></i>
                    </button>
                }
                <button class="cat-picker-done" @onclick="Close">Cancel</button>
            </div>
            <div class="cat-picker-list">
                @if (!Filtered.Any())
                {
                    <div class="cat-picker-empty">No templates found</div>
                }
                @foreach (TemplateDto t in Filtered)
                {
                    <button type="button" class="tpl-row" @onclick="() => Pick(t)">
                        <div class="tpl-row-info">
                            <span class="tpl-row-name">@t.Name</span>
                            @if (!string.IsNullOrEmpty(t.CategoryName))
                            {
                                <span class="tpl-row-cat">@t.CategoryName</span>
                            }
                        </div>
                        <span class="tpl-row-amount @(t.Type == RecordType.Expense ? "tpl-amount-expense" : "tpl-amount-income")">
                            @(t.Type == RecordType.Expense ? "-" : "+")@Math.Abs(t.Amount).ToString("F2")
                        </span>
                    </button>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<TemplateDto> Templates { get; set; } = [];
    [Parameter] public EventCallback<TemplateDto> OnSelect { get; set; }
    [Parameter] public bool FullCover { get; set; }

    bool open;
    string search = string.Empty;

    IEnumerable<TemplateDto> Filtered => string.IsNullOrEmpty(search)
        ? Templates
        : Templates.Where(t => t.Name.Contains(search, StringComparison.OrdinalIgnoreCase)
                             || t.CategoryName.Contains(search, StringComparison.OrdinalIgnoreCase));

    void Open()
    {
        open = true;
        search = string.Empty;
    }

    void Close()
    {
        open = false;
        search = string.Empty;
    }

    async Task Pick(TemplateDto template)
    {
        Close();
        await OnSelect.InvokeAsync(template);
    }
}
