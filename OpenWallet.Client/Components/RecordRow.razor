@using OpenWallet.Shared.DTOs
@using OpenWallet.Shared.Models

<div class="record-row" @onclick="() => OnClick.InvokeAsync(Record)">
    <div class="record-category-circle flex-shrink-0" style="background:@CircleBg">
        @if (Record.Type == RecordType.Transfer)
        {
            <i class="bi bi-arrow-left-right" style="color:#79c0ff"></i>
        }
        else
        {
            <i class="bi @Record.CategoryIcon" style="color:@Record.CategoryColor"></i>
        }
    </div>

    <div class="record-row-main">
        <div class="record-row-name">@(Record.Type == RecordType.Transfer ? "Transfer" : Record.CategoryName)</div>
        <div class="record-row-sub">
            <span style="color:@(string.IsNullOrEmpty(Record.AccountColor) ? "inherit" : Record.AccountColor)">@Record.AccountName</span>
            @if (!string.IsNullOrEmpty(Record.StoreName))
            {
                <span class="mx-1 opacity-50">·</span>@Record.StoreName
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Record.Notes) || Record.Attachments.Count > 0)
        {
            <div class="record-row-notes">
                @if (Record.Attachments.Count > 0)
                {
                    <i class="bi bi-paperclip me-1"></i>
                }
                @Record.Notes
            </div>
        }
    </div>

    <div class="record-row-right">
        <div class="record-row-amount @AmountClass">@FormattedAmount</div>
        <div class="record-row-date">@Record.DateTime.ToString("MMM dd, HH:mm")</div>
        @if (Record.Tags.Count > 0)
        {
            <div class="d-none d-sm-flex gap-1 justify-content-end flex-wrap mt-1">
                @foreach (TagDto t in Record.Tags.Take(3))
                {
                    <span class="tag-badge">@t.Name</span>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public RecordDto Record { get; set; } = new();
    [Parameter] public EventCallback<RecordDto> OnClick { get; set; }

    string CircleBg
    {
        get
        {
            if (Record.Type == RecordType.Transfer) return "rgba(121,192,255,0.15)";
            string c = Record.CategoryColor;
            if (string.IsNullOrEmpty(c) || !c.StartsWith('#') || c.Length < 7) return "#21262d";
            try
            {
                int r = Convert.ToInt32(c[1..3], 16);
                int g = Convert.ToInt32(c[3..5], 16);
                int b = Convert.ToInt32(c[5..7], 16);
                return $"rgba({r},{g},{b},0.15)";
            }
            catch { return "#21262d"; }
        }
    }

    string AmountClass => Record.Type switch
    {
        RecordType.Expense => "amount-negative",
        RecordType.Income  => "amount-positive",
        _                  => Record.Amount < 0 ? "amount-negative" : "amount-positive"
    };

    string FormattedAmount
    {
        get
        {
            string sign = Record.Type switch
            {
                RecordType.Expense => "−",
                RecordType.Income  => "+",
                _                  => Record.Amount < 0 ? "−" : "+"
            };
            return $"{sign}{Record.AccountCurrency} {Math.Abs(Record.Amount):N2}";
        }
    }
}
