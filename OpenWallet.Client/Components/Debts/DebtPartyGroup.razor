@using OpenWallet.Shared.DTOs

<div class="mb-3">
    <div class="widget-card d-flex align-items-center justify-content-between"
         style="cursor:pointer;" @onclick="Toggle">
        <div class="d-flex align-items-center gap-3">
            <i class="bi @(expanded ? "bi-chevron-down" : "bi-chevron-right") text-muted small"></i>
            <span class="fw-semibold">@PartyName</span>
            <span class="badge bg-secondary">@Debts.Count</span>
        </div>
        <div class="d-flex gap-4 small">
            <div class="text-end">
                <div class="text-muted">Total</div>
                <div class="fw-semibold">@Debts.Sum(d => d.Amount).ToString("N2")</div>
            </div>
            <div class="text-end">
                <div class="text-muted">Remaining</div>
                <div class="fw-semibold @(Debts.Sum(d => d.AmountRemaining) > 0 ? "amount-negative" : "amount-positive")">
                    @Debts.Sum(d => d.AmountRemaining).ToString("N2")
                </div>
            </div>
        </div>
    </div>

    @if (expanded)
    {
        <div class="row g-3 mt-1 ps-2">
            @foreach (DebtDto debt in Debts)
            {
                <div class="col-md-6 col-lg-4">
                    <DebtCard Debt="debt"
                              OnEdit="OnEdit"
                              OnDelete="OnDelete"
                              OnMarkResolved="OnMarkResolved" />
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string PartyName { get; set; } = string.Empty;
    [Parameter, EditorRequired] public List<DebtDto> Debts { get; set; } = [];
    [Parameter] public EventCallback<DebtDto> OnEdit { get; set; }
    [Parameter] public EventCallback<DebtDto> OnDelete { get; set; }
    [Parameter] public EventCallback<DebtDto> OnMarkResolved { get; set; }

    bool expanded = true;

    void Toggle() => expanded = !expanded;
}
