@using OpenWallet.Shared.DTOs

<div class="cat-row @(Selected ? "cat-row-selected" : "")" @onclick="HandleClick">
    <div class="record-category-circle flex-shrink-0" style="background:@CircleBg">
        <i class="bi @Category.Icon" style="color:@Category.Color; font-size:.95rem;"></i>
    </div>
    <div class="flex-grow-1 text-truncate">
        <div class="cat-row-name">@Category.Name</div>
        @if (!string.IsNullOrEmpty(Category.ParentCategoryName))
        {
            <div class="cat-row-sub">@Category.ParentCategoryName</div>
        }
    </div>
    @if (Category.SubCategories.Count > 0 && ShowDrill)
    {
        <i class="bi bi-chevron-right cat-drill-chevron"></i>
    }
</div>

@code {
    [Parameter, EditorRequired] public CategoryDto Category { get; set; } = new();
    [Parameter] public bool Selected { get; set; }
    [Parameter] public bool ShowDrill { get; set; } = true;
    [Parameter] public EventCallback OnSelect { get; set; }
    [Parameter] public EventCallback OnDrill { get; set; }

    void HandleClick()
    {
        if (ShowDrill && Category.SubCategories.Count > 0)
            OnDrill.InvokeAsync();
        else
            OnSelect.InvokeAsync();
    }

    string CircleBg
    {
        get
        {
            string c = Category.Color;
            if (string.IsNullOrEmpty(c) || !c.StartsWith('#') || c.Length < 7) return "#21262d";
            try
            {
                int r = Convert.ToInt32(c[1..3], 16);
                int g = Convert.ToInt32(c[3..5], 16);
                int b = Convert.ToInt32(c[5..7], 16);
                return $"rgba({r},{g},{b},0.15)";
            }
            catch { return "#21262d"; }
        }
    }
}
