@using OpenWallet.Shared.DTOs
@inject IJSRuntime JS

<div class="widget-card">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="mb-0 fw-semibold">Expenses</h6>
        <div class="btn-group btn-group-sm">
            <button class="btn @(pieTab == "category" ? "btn-primary" : "btn-outline-secondary")"
                    @onclick="@(() => SwitchTab("category"))">Category</button>
            <button class="btn @(pieTab == "tag" ? "btn-primary" : "btn-outline-secondary")"
                    @onclick="@(() => SwitchTab("tag"))">Tag</button>
        </div>
    </div>
    <canvas id="pieChart" height="200"></canvas>
    <div class="mt-3">
        @if (pieTab == "category")
        {
            @foreach (CategoryExpenseDto item in ExpensesByCategory.Take(5))
            {
                <div class="d-flex align-items-center justify-content-between mb-1 small">
                    <div>
                        <span class="pie-legend-dot" style="background-color: @item.CategoryColor"></span>
                        @item.CategoryName
                    </div>
                    <span class="@(IsMasked ? "masked" : "")">@item.Percentage%</span>
                </div>
            }
        }
        else
        {
            @foreach (TagExpenseDto item in ExpensesByTag.Take(5))
            {
                <div class="d-flex align-items-center justify-content-between mb-1 small">
                    <div><i class="bi bi-tag me-1"></i>@item.TagName</div>
                    <span class="@(IsMasked ? "masked" : "")">@item.Percentage%</span>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public List<CategoryExpenseDto> ExpensesByCategory { get; set; } = [];
    [Parameter, EditorRequired] public List<TagExpenseDto> ExpensesByTag { get; set; } = [];
    [Parameter] public bool IsMasked { get; set; }

    string pieTab = "category";
    bool chartDirty = true;

    protected override void OnParametersSet() => chartDirty = true;

    void SwitchTab(string tab)
    {
        pieTab = tab;
        chartDirty = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!chartDirty) return;
        chartDirty = false;

        List<string> labels = pieTab == "category"
            ? ExpensesByCategory.Select(e => e.CategoryName).ToList()
            : ExpensesByTag.Select(e => e.TagName).ToList();

        List<decimal> data = pieTab == "category"
            ? ExpensesByCategory.Select(e => e.Amount).ToList()
            : ExpensesByTag.Select(e => e.Amount).ToList();

        List<string> colors = pieTab == "category"
            ? ExpensesByCategory.Select(e => e.CategoryColor).ToList()
            : ExpensesByTag.Select(_ => "#388bfd").ToList();

        await JS.InvokeVoidAsync("renderPieChart", "pieChart", labels, data, colors);
    }
}
