@using OpenWallet.Shared.DTOs

<div class="cat-picker @(FullCover ? "full-cover" : "")">
    <button type="button" class="cat-picker-trigger @(open ? "open" : "")" @onclick="ToggleOpen">
        @if (SelectedTags.Any())
        {
            <i class="bi bi-tags me-2 text-muted flex-shrink-0"></i>
            <span class="text-truncate">@string.Join(", ", SelectedTags.Select(t => t.Name))</span>
        }
        else
        {
            <i class="bi bi-tags me-2 text-muted"></i>
            <span class="text-muted">@Placeholder</span>
        }
        <i class="bi bi-chevron-down ms-auto cat-picker-chevron @(open ? "rotated" : "")"></i>
    </button>

    @if (open)
    {
        @if (!FullCover)
        {
            <div class="cat-picker-backdrop" @onclick="Close"></div>
        }
        <div class="cat-picker-panel @(FullCover ? "full-cover" : "")">
            <div class="cat-picker-search">
                <i class="bi bi-search text-muted me-2"></i>
                <input class="cat-picker-input" @bind="search" @bind:event="oninput"
                       placeholder="Search tags…" />
                @if (!string.IsNullOrEmpty(search))
                {
                    <button class="cat-picker-clear" @onclick="() => search = string.Empty">
                        <i class="bi bi-x"></i>
                    </button>
                }
                @if (FullCover)
                {
                    <button class="cat-picker-done" @onclick="Close">Done</button>
                }
            </div>
            <div class="cat-picker-list">
                @if (!Filtered.Any())
                {
                    <div class="cat-picker-empty">No tags found</div>
                }
                @foreach (TagDto t in Filtered)
                {
                    bool sel = SelectedIds.Contains(t.Id);
                    <button type="button" class="picker-row @(sel ? "picker-row-active" : "")"
                            @onclick="@(() => ToggleTag(t.Id))">
                        <i class="bi bi-tag text-muted"></i>
                        <span class="text-truncate">@t.Name</span>
                        @if (sel) { <i class="bi bi-check2 ms-auto text-primary"></i> }
                    </button>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<TagDto> Tags { get; set; } = [];
    [Parameter] public List<int> SelectedIds { get; set; } = [];
    [Parameter] public EventCallback<List<int>> SelectedIdsChanged { get; set; }
    [Parameter] public bool FullCover { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Select tags…";

    bool open;
    string search = string.Empty;

    IEnumerable<TagDto> SelectedTags => Tags.Where(t => SelectedIds.Contains(t.Id));

    IEnumerable<TagDto> Filtered => string.IsNullOrEmpty(search)
        ? Tags
        : Tags.Where(t => t.Name.Contains(search, StringComparison.OrdinalIgnoreCase));

    void ToggleOpen()
    {
        if (open) Close();
        else { open = true; search = string.Empty; }
    }

    void Close()
    {
        open = false;
        search = string.Empty;
    }

    async Task ToggleTag(int tagId)
    {
        List<int> updated = [..SelectedIds];
        if (updated.Contains(tagId)) updated.Remove(tagId);
        else updated.Add(tagId);
        await SelectedIdsChanged.InvokeAsync(updated);
    }
}
