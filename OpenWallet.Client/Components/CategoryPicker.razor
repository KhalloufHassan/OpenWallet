@using OpenWallet.Shared.DTOs

<div class="cat-picker">
    @* Trigger *@
    <button type="button" class="cat-picker-trigger @(open ? "open" : "")" @onclick="Toggle">
        @if (Selected != null)
        {
            <div class="record-category-circle flex-shrink-0" style="background:@SelectedBg; width:28px; height:28px; font-size:.8rem;">
                <i class="bi @Selected.Icon" style="color:@Selected.Color;"></i>
            </div>
            <span class="ms-2 text-truncate">@Selected.Name</span>
        }
        else
        {
            <i class="bi bi-grid me-2 text-muted"></i>
            <span class="text-muted">@Placeholder</span>
        }
        <i class="bi bi-chevron-down ms-auto cat-picker-chevron @(open ? "rotated" : "")"></i>
    </button>

    @* Panel *@
    @if (open)
    {
        <div class="cat-picker-backdrop" @onclick="Close"></div>
        <div class="cat-picker-panel">
            @* Search *@
            <div class="cat-picker-search">
                <i class="bi bi-search text-muted me-2"></i>
                <input class="cat-picker-input" @bind="search" @bind:event="oninput"
                       @ref="searchInput" placeholder="Search categories…" />
                @if (!string.IsNullOrEmpty(search))
                {
                    <button class="cat-picker-clear" @onclick="() => search = string.Empty">
                        <i class="bi bi-x"></i>
                    </button>
                }
            </div>

            @* Breadcrumb / back button *@
            @if (drillParent != null && string.IsNullOrEmpty(search))
            {
                <div class="cat-picker-breadcrumb">
                    <button class="cat-picker-back" @onclick="GoBack">
                        <i class="bi bi-arrow-left me-1"></i>Back
                    </button>
                    <span class="small fw-semibold text-truncate">@drillParent.Name</span>
                </div>
                @* Allow selecting the parent itself *@
                <div class="cat-picker-use-parent" @onclick="() => Select(drillParent)">
                    <i class="bi bi-check2 me-2"></i>Use "@drillParent.Name"
                </div>
            }

            @* Category rows *@
            <div class="cat-picker-list @listAnim" @key="listKey">
                @if (!VisibleCategories.Any())
                {
                    <div class="cat-picker-empty">No categories found</div>
                }
                else
                {
                    @foreach (CategoryDto cat in VisibleCategories)
                    {
                        <CategoryRow Category="cat"
                                     Selected="cat.Id == Value"
                                     ShowDrill="@(cat.SubCategories.Count > 0 && string.IsNullOrEmpty(search))"
                                     OnSelect="() => Select(cat)"
                                     OnDrill="() => DrillInto(cat)" />
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<CategoryDto> Categories { get; set; } = [];
    [Parameter] public int? Value { get; set; }
    [Parameter] public EventCallback<int?> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Select category…";

    bool open;
    string search = string.Empty;
    CategoryDto? drillParent;
    string listAnim = string.Empty;
    int listKey;
    ElementReference searchInput;

    CategoryDto? Selected => Value.HasValue
        ? FlatAll(Categories).FirstOrDefault(c => c.Id == Value.Value)
        : null;

    string SelectedBg
    {
        get
        {
            string c = Selected?.Color ?? "";
            if (string.IsNullOrEmpty(c) || !c.StartsWith('#') || c.Length < 7) return "#21262d";
            try
            {
                int r = Convert.ToInt32(c[1..3], 16);
                int g = Convert.ToInt32(c[3..5], 16);
                int b = Convert.ToInt32(c[5..7], 16);
                return $"rgba({r},{g},{b},0.15)";
            }
            catch { return "#21262d"; }
        }
    }

    IEnumerable<CategoryDto> VisibleCategories
    {
        get
        {
            if (!string.IsNullOrEmpty(search))
                return FlatAll(Categories)
                    .Where(c => c.Name.Contains(search, StringComparison.OrdinalIgnoreCase));
            return drillParent?.SubCategories ?? Categories;
        }
    }

    void Toggle()
    {
        if (open) Close();
        else Open();
    }

    void Open()
    {
        open = true;
        search = string.Empty;
        drillParent = null;
        listAnim = string.Empty;
    }

    void Close()
    {
        open = false;
        search = string.Empty;
        drillParent = null;
    }

    void DrillInto(CategoryDto parent)
    {
        drillParent = parent;
        search = string.Empty;
        listAnim = "cat-slide-in";
        listKey++;
    }

    void GoBack()
    {
        drillParent = null;
        listAnim = "cat-slide-back";
        listKey++;
    }

    async Task Select(CategoryDto cat)
    {
        await ValueChanged.InvokeAsync(cat.Id);
        Close();
    }

    static IEnumerable<CategoryDto> FlatAll(IEnumerable<CategoryDto> cats)
    {
        foreach (CategoryDto c in cats)
        {
            yield return c;
            foreach (CategoryDto sub in FlatAll(c.SubCategories))
                yield return sub;
        }
    }
}
