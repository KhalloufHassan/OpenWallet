@page "/security"
@using OpenWallet.Client.Services
@using OpenWallet.Shared.DTOs
@inject ApiClient Api
@inject IJSRuntime JS

<div class="d-flex align-items-center mb-4 gap-3">
    <i class="bi bi-shield-lock fs-3 text-primary"></i>
    <div>
        <h4 class="mb-0 fw-semibold">Security</h4>
        <p class="text-muted small mb-0">Manage two-factor authentication and passkeys</p>
    </div>
</div>

@if (loading)
{
    <div class="text-center text-muted py-5">
        <span class="spinner-border spinner-border-sm me-2"></span>Loading…
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="widget-card h-100">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-phone text-warning"></i>
                    <h6 class="mb-0 fw-semibold">Authenticator App (TOTP)</h6>
                </div>

                @if (status?.TotpEnabled == true)
                {
                    <p class="text-success small mb-3">
                        <i class="bi bi-check-circle-fill me-1"></i>Enabled
                    </p>
                    <button class="btn btn-sm btn-outline-danger" @onclick="StartDisableTotp" disabled="@busy">
                        Disable TOTP
                    </button>
                }
                else if (totpSetup != null)
                {
                    <p class="small text-muted mb-2">Scan this QR code with your authenticator app:</p>
                    <div id="totp-qr" class="mb-3 d-flex justify-content-center"></div>
                    <p class="small text-muted mb-1">Or enter this key manually:</p>
                    <code class="d-block mb-3 user-select-all small">@totpSetup.Key</code>
                    <p class="small text-muted mb-2">Enter the 6-digit code from your app to confirm:</p>
                    <div class="input-group mb-2">
                        <input class="form-control text-center" @bind="totpVerifyCode" placeholder="000000"
                               maxlength="6" inputmode="numeric" autocomplete="one-time-code" />
                        <button class="btn btn-primary" @onclick="ConfirmEnableTotp" disabled="@busy">Enable</button>
                    </div>
                    @if (!string.IsNullOrEmpty(totpError))
                    {
                        <div class="alert alert-danger py-1 small">@totpError</div>
                    }
                    <button class="btn btn-sm btn-link text-muted p-0 mt-1" @onclick="() => totpSetup = null">Cancel</button>
                }
                else
                {
                    <p class="text-muted small mb-3">
                        <i class="bi bi-x-circle me-1"></i>Not enabled
                    </p>
                    <button class="btn btn-sm btn-outline-primary" @onclick="StartSetupTotp" disabled="@busy">
                        Set up Authenticator App
                    </button>
                }
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="widget-card h-100">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-key text-primary"></i>
                        <h6 class="mb-0 fw-semibold">Passkeys &amp; Security Keys</h6>
                    </div>
                    @if (webAuthnSupported && !addingPasskey)
                    {
                        <div class="d-flex gap-2">
                            @if (passkeyPlatformSupported)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowAddPasskey(platform: true)" disabled="@busy">
                                    <i class="bi bi-person-badge me-1"></i>Face/Touch ID
                                </button>
                            }
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowAddPasskey(platform: false)" disabled="@busy">
                                <i class="bi bi-usb-symbol me-1"></i>Security Key
                            </button>
                        </div>
                    }
                </div>

                @if (!webAuthnSupported)
                {
                    <p class="text-muted small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Your browser does not support WebAuthn / passkeys.
                    </p>
                }
                else if (addingPasskey)
                {
                    <div class="mb-3">
                        <label class="form-label small">Name this key</label>
                        <input class="form-control form-control-sm" @bind="newPasskeyName" placeholder="e.g. YubiKey, iPhone Face ID" />
                    </div>
                    @if (!string.IsNullOrEmpty(passkeyError))
                    {
                        <div class="alert alert-danger py-1 small">@passkeyError</div>
                    }
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-primary" @onclick="RegisterPasskey" disabled="@busy">
                            @if (busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Register Key
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => { addingPasskey = false; passkeyError = string.Empty; }">Cancel</button>
                    </div>
                }
                else if (status?.Passkeys.Count == 0)
                {
                    <p class="text-muted small">No passkeys registered yet.</p>
                }
                else
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (PasskeyInfoDto passkey in status?.Passkeys ?? [])
                        {
                            <li class="d-flex align-items-center justify-content-between py-2 border-bottom border-secondary-subtle">
                                <div>
                                    <div class="small fw-semibold">
                                        <i class="bi bi-key me-1 opacity-50"></i>@passkey.Name
                                    </div>
                                    <div class="text-muted" style="font-size:.75rem;">
                                        Added @passkey.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")
                                    </div>
                                </div>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePasskey(passkey.Id)" disabled="@busy">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </li>
                        }
                    </ul>
                }

                @if (!string.IsNullOrEmpty(passkeyError) && !addingPasskey)
                {
                    <div class="alert alert-danger py-1 small mt-2">@passkeyError</div>
                }
                @if (!string.IsNullOrEmpty(passkeySuccess))
                {
                    <div class="alert alert-success py-1 small mt-2">@passkeySuccess</div>
                }
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="widget-card h-100">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-key-fill text-secondary"></i>
                    <h6 class="mb-0 fw-semibold">Change Password</h6>
                </div>

                <div class="mb-3">
                    <label class="form-label small">Current Password</label>
                    <input type="password" class="form-control" @bind="pwCurrent" autocomplete="current-password" />
                </div>
                <div class="mb-3">
                    <label class="form-label small">New Password</label>
                    <input type="password" class="form-control" @bind="pwNew" autocomplete="new-password" />
                </div>
                <div class="mb-3">
                    <label class="form-label small">Confirm New Password</label>
                    <input type="password" class="form-control" @bind="pwConfirm" autocomplete="new-password" />
                </div>

                @if (!string.IsNullOrEmpty(pwError))
                {
                    <div class="alert alert-danger py-1 small mb-2">@pwError</div>
                }
                @if (!string.IsNullOrEmpty(pwSuccess))
                {
                    <div class="alert alert-success py-1 small mb-2">@pwSuccess</div>
                }

                <button class="btn btn-sm btn-outline-primary" @onclick="ChangePassword" disabled="@busy">
                    @if (busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Update Password
                </button>
            </div>
        </div>
    </div>
}

@code {
    SecurityStatusDto? status;
    TotpSetupDto? totpSetup;
    string totpVerifyCode = string.Empty;
    string totpError = string.Empty;
    bool loading = true;
    bool busy;
    bool webAuthnSupported;
    bool passkeyPlatformSupported;
    bool addingPasskey;
    bool addingPlatformPasskey;
    string newPasskeyName = string.Empty;
    string passkeyError = string.Empty;
    string passkeySuccess = string.Empty;
    string pwCurrent = string.Empty;
    string pwNew = string.Empty;
    string pwConfirm = string.Empty;
    string pwError = string.Empty;
    string pwSuccess = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        status = await Api.GetSecurityStatusAsync();
        loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            webAuthnSupported = await JS.InvokeAsync<bool>("owAuth.isWebAuthnSupported");
            if (webAuthnSupported)
                passkeyPlatformSupported = await JS.InvokeAsync<bool>("owAuth.isPasskeySupported");
            StateHasChanged();
        }

        if (totpSetup != null)
        {
            try
            {
                await JS.InvokeVoidAsync("owAuth.renderQrCode", "totp-qr", totpSetup.QrCodeUri);
            }
            catch
            {
                // ignored
            }
        }
    }

    async Task StartSetupTotp()
    {
        busy = true;
        totpSetup = await Api.SetupTotpAsync();
        totpError = string.Empty;
        busy = false;
    }

    async Task ConfirmEnableTotp()
    {
        if (string.IsNullOrWhiteSpace(totpVerifyCode)) return;
        busy = true;
        totpError = string.Empty;

        bool ok = await Api.EnableTotpAsync(new VerifyTotpDto { Code = totpVerifyCode });
        busy = false;

        if (!ok)
        {
            totpError = "Invalid code. Please try again.";
            totpVerifyCode = string.Empty;
            return;
        }

        totpSetup = null;
        totpVerifyCode = string.Empty;
        status = await Api.GetSecurityStatusAsync();
    }

    async Task StartDisableTotp()
    {
        busy = true;
        await Api.DisableTotpAsync();
        busy = false;
        status = await Api.GetSecurityStatusAsync();
    }

    void ShowAddPasskey(bool platform)
    {
        addingPasskey = true;
        addingPlatformPasskey = platform;
        passkeyError = string.Empty;
        passkeySuccess = string.Empty;
        newPasskeyName = string.Empty;
    }

    async Task RegisterPasskey()
    {
        if (string.IsNullOrWhiteSpace(newPasskeyName)) return;
        busy = true;
        passkeyError = string.Empty;

        try
        {
            string optionsJson = await Api.GetPasskeyRegisterOptionsAsync(new RegisterPasskeyNameDto { Name = newPasskeyName, Platform = addingPlatformPasskey });
            string credentialJson = await JS.InvokeAsync<string>("owAuth.passkeyRegister", optionsJson);
            (PasskeyInfoDto? info, string? regError) = await Api.CompletePasskeyRegisterAsync(credentialJson);

            if (info == null)
            {
                passkeyError = regError ?? "Registration failed. Please try again.";
                return;
            }

            addingPasskey = false;
            passkeySuccess = $"Passkey \"{info.Name}\" registered successfully.";
            status = await Api.GetSecurityStatusAsync();
            if (addingPlatformPasskey)
                await JS.InvokeVoidAsync("owAuth.setPlatformKey", true);
        }
        catch (JSException jsEx)
        {
            passkeyError = jsEx.Message.Contains("cancelled") || jsEx.Message.Contains("abort")
                ? "Registration was cancelled."
                : "Passkey registration failed.";
        }
        catch
        {
            passkeyError = "Passkey registration failed.";
        }
        finally
        {
            busy = false;
        }
    }

    async Task DeletePasskey(int id)
    {
        busy = true;
        passkeyError = string.Empty;
        passkeySuccess = string.Empty;
        bool ok = await Api.DeletePasskeyAsync(id);
        busy = false;

        if (ok)
        {
            status = await Api.GetSecurityStatusAsync();
            bool anyPlatform = status?.Passkeys.Any() == true;
            if (!anyPlatform)
                await JS.InvokeVoidAsync("owAuth.setPlatformKey", false);
        }
        else
        {
            passkeyError = "Failed to delete passkey.";
        }
    }

    async Task ChangePassword()
    {
        pwError = string.Empty;
        pwSuccess = string.Empty;

        if (string.IsNullOrWhiteSpace(pwCurrent) || string.IsNullOrWhiteSpace(pwNew))
        { pwError = "All fields are required."; return; }

        if (pwNew.Length < 12)
        { pwError = "New password must be at least 12 characters."; return; }

        if (!pwNew.Any(char.IsDigit) || !pwNew.Any(char.IsLower))
        { pwError = "New password must contain at least one digit and one lowercase letter."; return; }

        if (pwNew != pwConfirm)
        { pwError = "Passwords do not match."; return; }

        busy = true;
        bool ok = await Api.ChangePasswordAsync(new ChangePasswordDto { CurrentPassword = pwCurrent, NewPassword = pwNew });
        busy = false;

        if (ok)
        {
            pwSuccess = "Password updated successfully.";
            pwCurrent = string.Empty;
            pwNew = string.Empty;
            pwConfirm = string.Empty;
        }
        else
        {
            pwError = "Current password is incorrect.";
        }
    }
}
