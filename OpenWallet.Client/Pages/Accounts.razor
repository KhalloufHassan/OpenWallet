@page "/accounts"
@using OpenWallet.Client.Services
@using OpenWallet.Shared.DTOs
@using OpenWallet.Shared.Constants
@inject ApiClient Api

<PageTitle>Accounts - OpenWallet</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-semibold">Accounts</h4>
    <button class="btn btn-primary btn-sm" @onclick="() => OpenModal(null)">
        <i class="bi bi-plus-lg me-1"></i>Add Account
    </button>
</div>

@if (loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="row g-3">
        @foreach (AccountDto account in accounts)
        {
            <div class="col-md-6 col-lg-4">
                <div class="widget-card">
                    <div class="d-flex align-items-start justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <span class="account-color-dot" style="background-color: @account.Color"></span>
                            <span class="fw-semibold">@account.Name</span>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenModal(account)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(account)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mt-3">
                        <div class="text-muted small">Currency</div>
                        <div class="fw-semibold">@account.Currency</div>
                    </div>
                    <div class="mt-2">
                        <div class="text-muted small">Initial Amount</div>
                        <div>@account.Currency @account.InitialAmount.ToString("N2")</div>
                    </div>
                    <div class="mt-2">
                        <div class="text-muted small">Current Balance</div>
                        <div class="fs-5 fw-bold @(account.CurrentBalance >= 0 ? "amount-positive" : "amount-negative")">
                            @account.Currency @account.CurrentBalance.ToString("N2")
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingId == null ? "Add Account" : "Edit Account")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" @bind="form.Name" placeholder="e.g. Main Checking" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Currency</label>
                        <select class="form-select" @bind="form.Currency">
                            <option value="">Select currency...</option>
                            @foreach (string c in Currencies.All)
                            {
                                <option value="@c">@c</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Initial Amount</label>
                        <input type="number" class="form-control" @bind="form.InitialAmount" step="0.01" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Color</label>
                        <input type="color" class="form-control form-control-color" @bind="form.Color" />
                    </div>
                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="alert alert-danger py-2">@error</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                        @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (deleteTarget != null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Account</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => deleteTarget = null"></button>
                </div>
                <div class="modal-body">
                    Delete account <strong>@deleteTarget.Name</strong>? This cannot be undone.
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => deleteTarget = null">Cancel</button>
                    <button class="btn btn-danger" @onclick="ExecuteDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<AccountDto> accounts = [];
    bool loading = true;
    bool showModal = false;
    bool saving = false;
    string error = string.Empty;
    int? editingId = null;
    AccountDto? deleteTarget;

    CreateAccountDto form = new() { Color = "#388bfd" };

    protected override async Task OnInitializedAsync()
    {
        accounts = await Api.GetAccountsAsync();
        loading = false;
    }

    void OpenModal(AccountDto? account)
    {
        error = string.Empty;
        if (account == null)
        {
            editingId = null;
            form = new CreateAccountDto { Color = "#388bfd" };
        }
        else
        {
            editingId = account.Id;
            form = new CreateAccountDto
            {
                Name = account.Name,
                Currency = account.Currency,
                InitialAmount = account.InitialAmount,
                Color = account.Color
            };
        }
        showModal = true;
    }

    void CloseModal() => showModal = false;

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(form.Name) || string.IsNullOrWhiteSpace(form.Currency))
        {
            error = "Name and currency are required.";
            return;
        }
        saving = true;
        try
        {
            if (editingId == null)
                await Api.CreateAccountAsync(form);
            else
                await Api.UpdateAccountAsync(editingId.Value, new UpdateAccountDto
                {
                    Name = form.Name,
                    Currency = form.Currency,
                    InitialAmount = form.InitialAmount,
                    Color = form.Color
                });

            accounts = await Api.GetAccountsAsync();
            showModal = false;
        }
        catch (Exception ex) { error = ex.Message; }
        finally { saving = false; }
    }

    void ConfirmDelete(AccountDto account) => deleteTarget = account;

    async Task ExecuteDelete()
    {
        if (deleteTarget == null) return;
        await Api.DeleteAccountAsync(deleteTarget.Id);
        accounts = await Api.GetAccountsAsync();
        deleteTarget = null;
    }
}
